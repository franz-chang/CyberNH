{"metric_id":"M-CNH-006A-001","source":"rules/raw/规则.pdf","section":"6.A Task Interruption and Preemption Logic","page":1,"name":"Interrupted task count","category":"system_side","definition":"Number of tasks interrupted due to preemption.","unit":"count","formula":"count(tasks where interruption_event == true)","aggregation_level":"scenario, shift, run","event_fields_required":["task_id","interruption_event","tick","reason"]}
{"metric_id":"M-CNH-006A-002","source":"rules/raw/规则.pdf","section":"6.A Task Interruption and Preemption Logic","page":1,"name":"Preemption added delay","category":"system_side","definition":"Delay added to interrupted tasks because of preemption.","unit":"minutes","formula":"sum(resume_or_completion_time_after_preemption - expected_completion_time_without_preemption)","aggregation_level":"task, scenario, shift, run","event_fields_required":["task_id","preemption_tick","original_remaining_time","resume_tick","completion_tick"]}
{"metric_id":"M-CNH-007-001","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Average waiting time","category":"resident_side","definition":"Mean time from call to caregiver arrival.","unit":"minutes","formula":"mean(first_caregiver_arrival_tick - demand_created_tick)","aggregation_level":"scenario, shift, run","event_fields_required":["demand_id","demand_created_tick","first_caregiver_arrival_tick"]}
{"metric_id":"M-CNH-007-002","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Coordination waiting time","category":"caregiver_side","definition":"Time the first agent waits for the second agent to arrive.","unit":"minutes","formula":"second_caregiver_arrival_tick - first_caregiver_arrival_tick for two-person tasks","aggregation_level":"task, caregiver, scenario, shift, run","event_fields_required":["demand_id","required_workers","first_caregiver_arrival_tick","second_caregiver_arrival_tick"]}
{"metric_id":"M-CNH-007-003","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"P95 waiting time","category":"resident_side","definition":"95th percentile of waiting times.","unit":"minutes","formula":"percentile(waiting_time_minutes, 95)","aggregation_level":"scenario, shift, run","event_fields_required":["demand_id","waiting_time_minutes"]}
{"metric_id":"M-CNH-007-004","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Timeout or overtime rate","category":"resident_side","definition":"Proportion of calls with waiting time greater than the secondary-call threshold.","unit":"percent","formula":"count(waiting_time_minutes > secondary_call_threshold_minutes) / count(generated_calls)","aggregation_level":"scenario, shift, run","event_fields_required":["demand_id","waiting_time_minutes","secondary_call_threshold_minutes"]}
{"metric_id":"M-CNH-007-005","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Total walking distance","category":"caregiver_side","definition":"Cumulative walking distance per caregiver per shift.","unit":"meters_per_shift","formula":"sum(distance_moved_meters) grouped by caregiver_id and shift_id","aggregation_level":"caregiver, shift, run","event_fields_required":["caregiver_id","shift_id","distance_moved_meters"]}
{"metric_id":"M-CNH-007-006","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Total task processing time","category":"caregiver_side","definition":"Sum of time spent actively executing tasks per shift, excluding idle.","unit":"minutes_per_shift","formula":"sum(active_task_execution_minutes) grouped by caregiver_id and shift_id","aggregation_level":"caregiver, shift, run","event_fields_required":["caregiver_id","shift_id","active_task_execution_minutes","status"]}
{"metric_id":"M-CNH-007-007","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Heavy-task count distribution","category":"caregiver_side","definition":"Distribution of heavy tasks handled per caregiver, reported using standard deviation or Gini coefficient.","unit":"count_distribution","formula":"stddev(heavy_task_count_by_caregiver) and/or gini(heavy_task_count_by_caregiver)","aggregation_level":"caregiver_group, shift, run","event_fields_required":["caregiver_id","task_class","completed_task_count"]}
{"metric_id":"M-CNH-007-008","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Task completion rate","category":"system_side","definition":"Completed tasks divided by generated tasks.","unit":"percent","formula":"completed_task_count / generated_task_count","aggregation_level":"scenario, shift, run","event_fields_required":["generated_task_count","completed_task_count"]}
{"metric_id":"M-CNH-007-009","source":"rules/raw/规则.pdf","section":"7 Quantifiable Output Metrics","page":3,"name":"Caregiver utilization","category":"caregiver_side","definition":"Task time plus movement time divided by total on-duty time.","unit":"percent","formula":"(task_time_minutes + movement_time_minutes) / total_on_duty_minutes","aggregation_level":"caregiver, shift, run","event_fields_required":["caregiver_id","task_time_minutes","movement_time_minutes","total_on_duty_minutes"]}
